# Auto detect text files and ensure LF line endings
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.ejs text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerignore text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf

# Shell
*.sh text eol=lf

# Git
.gitattributes text eol=lf
.gitignore text eol=lf

# Lock files
package-lock.json text eol=lf -diff

# Binary — do not touch
*.db binary
*.sqlite binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
