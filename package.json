{
  "name": "channel-statistics-bot",
  "version": "1.0.0",
  "description": "Telegram channel statistics bot with web dashboard",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.yml\"",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "12.8.0",
    "dotenv": "17.3.1",
    "ejs": "5.0.1",
    "express": "5.2.1",
    "pino": "9.6.0",
    "telegraf": "4.16.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/pino": "7.0.5",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml}": [
      "prettier --write"
    ]
  }
}
