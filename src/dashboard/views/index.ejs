<%- include('layout', {
  title: channelTitle + ' — Statistics',
  channelTitle,
  page: 'overview',
  body: `
    <div class="kpi-row">
      <div class="kpi">
        <div class="kpi-label">Members</div>
        <div class="kpi-value" id="kpiMembers">—</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Reactions (30d)</div>
        <div class="kpi-value" id="kpiReactions">—</div>
      </div>
    </div>

    <div class="date-range">
      <label>From</label>
      <input type="date" id="dateFrom">
      <label>To</label>
      <input type="date" id="dateTo">
      <button onclick="applyDateRange()">Apply</button>
    </div>

    <div class="card">
      <h2>Member Count</h2>
      <div class="loading" id="membersLoading"><div class="spinner"></div></div>
      <div class="chart-container" style="display:none;">
        <canvas id="membersChart"></canvas>
      </div>
      <div id="membersEmpty" class="empty-state" style="display:none;">
        No member data yet. The bot collects data every 2 hours.
      </div>
    </div>

    <div class="card">
      <h2>Daily Reactions</h2>
      <div class="loading" id="reactionsLoading"><div class="spinner"></div></div>
      <div class="chart-container" style="display:none;">
        <canvas id="reactionsChart"></canvas>
      </div>
      <div id="reactionsEmpty" class="empty-state" style="display:none;">
        No reaction data yet.
      </div>
    </div>

    <script>
      const charts = {};

      // Default date range: last 30 days
      const now = new Date();
      const thirtyAgo = new Date();
      thirtyAgo.setDate(now.getDate() - 30);
      document.getElementById('dateFrom').value = thirtyAgo.toISOString().slice(0, 10);
      document.getElementById('dateTo').value = now.toISOString().slice(0, 10);

      function dateParams() {
        const from = document.getElementById('dateFrom').value;
        const to = document.getElementById('dateTo').value;
        return 'from=' + encodeURIComponent(from + ' 00:00:00') + '&to=' + encodeURIComponent(to + ' 23:59:59');
      }

      async function loadChart(url, canvasId, emptyId, loadingId, label, valueKey, color) {
        const loadingEl = document.getElementById(loadingId);
        const canvasEl = document.getElementById(canvasId);
        const containerEl = canvasEl.parentElement;
        const emptyEl = document.getElementById(emptyId);

        loadingEl.style.display = 'block';
        containerEl.style.display = 'none';
        emptyEl.style.display = 'none';

        const res = await fetch(url + '?' + dateParams());
        const data = await res.json();

        loadingEl.style.display = 'none';

        if (data.length === 0) {
          emptyEl.style.display = 'block';
          return null;
        }

        containerEl.style.display = 'block';

        if (charts[canvasId]) {
          charts[canvasId].destroy();
        }

        charts[canvasId] = new Chart(canvasEl, {
          type: 'line',
          data: {
            labels: data.map(d => d.date),
            datasets: [{
              label: label,
              data: data.map(d => d[valueKey]),
              borderColor: color,
              backgroundColor: color + '20',
              fill: true,
              tension: 0.3,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: { display: true },
              y: { beginAtZero: false }
            }
          }
        });

        return data;
      }

      async function loadKPIs() {
        const [members, reactions] = await Promise.all([
          fetch('/api/members?' + dateParams()).then(r => r.json()),
          fetch('/api/reactions?' + dateParams()).then(r => r.json()),
        ]);

        const latestMembers = members.length > 0 ? members[members.length - 1].count : 0;
        const totalReactions = reactions.reduce((sum, d) => sum + d.total_reactions, 0);

        document.getElementById('kpiMembers').textContent = latestMembers.toLocaleString();
        document.getElementById('kpiReactions').textContent = totalReactions.toLocaleString();
      }

      function loadAll() {
        loadKPIs();
        loadChart('/api/members', 'membersChart', 'membersEmpty', 'membersLoading', 'Members', 'count', '#3b82f6');
        loadChart('/api/reactions', 'reactionsChart', 'reactionsEmpty', 'reactionsLoading', 'Reactions', 'total_reactions', '#f59e0b');
      }

      function applyDateRange() {
        loadAll();
      }

      loadAll();
    </script>
  `
}) %>
